# 默认 LLM Provider (openai/qwen/glm/ollama/MiniMax-M2.5)
DEFAULT_LLM_PROVIDER=MiniMax-M2.5

# BASE_URL=https://apis.iflow.cn/v1
BASE_URL=https://api.minimaxi.com/v1

# LLM API Keys (至少配置一个)
DASHSCOPE_API_KEY=xxxx

# AI 增强评分 (可选,默认: false)
# 启用后使用 AI 进行深度候选人评估,识别语义相似技能、评估经验质量、推断软技能
# 成本: 每个候选人约 ¥0.042 (~$0.006)
# 设置为 "true" 启用, "false" 或不设置则使用传统算法评分
USE_AI_ENHANCED_MATCHER=false

# 增强版报告 (可选,默认: false)
# 启用后生成多层次、视觉优化的评估报告,包含AI亮点/关注点卡片、对比分析、面试建议等
# 完全向后兼容,关闭后使用传统报告布局
# 设置为 "true" 启用增强版, "false" 或不设置则使用传统版
USE_ENHANCED_REPORT=false

